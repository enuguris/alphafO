# ===== AlphaFO Configuration =====

# App
APP_MODE=testing          # testing | paper | live
DEBUG=true
SECRET_KEY=change-me-to-random-256-bit-key

# Database
DATABASE_URL=postgresql+asyncpg://alphafO:password@localhost:5432/alphafO
POSTGRES_USER=alphafO
POSTGRES_PASSWORD=password
POSTGRES_DB=alphafO

# Redis
REDIS_URL=redis://localhost:6379/0

# Zerodha Kite Connect (required for paper/live modes)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=        # refreshed daily via OAuth

# Risk Parameters (defaults, overridable via UI)
MAX_CAPITAL_RISK_PER_TRADE=0.01    # 1%
MAX_PORTFOLIO_HEAT=0.03            # 3%
DAILY_LOSS_LIMIT=0.02              # 2%
WEEKLY_LOSS_LIMIT=0.03             # 3%

# Paper Trading Promotion Thresholds
PAPER_MIN_TRADES=60
PAPER_MIN_WIN_RATE=0.55
PAPER_MAX_DRAWDOWN=0.10

# Data
NSE_DATA_DIR=./data/nse
INITIAL_CAPITAL=500000             # ₹5,00,000 for paper trading
